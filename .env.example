# Neon PostgreSQL
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/orus-gallery?sslmode=require"
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/orus-gallery?sslmode=require"

# better_auth
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudflare R2 (optional — images fall back to data URLs if not set)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="orus-gallery"
R2_PUBLIC_URL=""

# Google Analytics 4 — Measurement ID (e.g. G-XXXXXXXXXX)
# Provided by site owner via the GA4 property data stream.
# Without this var, GA components do not render — site is fully GA-free.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
