  "home": {
    "hero": {
      "title": "ORUS GALLERY",
      "subtitle": "台北 — 巴黎",
      "tagline": "國際藝術畫廊"
    },
    "gallery": {
      "eyebrow": "探索",
      "title": "精選作品",
      "subtitle": "能夠轉換語境而不改變本質的作品",
      "cta": "查看所有藝術家"
    },
    "curatorial": {
      "eyebrow": "我們的方法",
      "title": "策展方向",
      "text1": "以親密為文化之橋。我們相信最私密的藝術也是最普世的。我們精選的每件作品都源於一種內在的必然——一個手勢、一種執念、一個未解的問題——超越了地理和文化的界限。",
      "text2": "這一信念指引著我們在台北與巴黎之間的工作：發掘那些根植於親密感、卻能與所有人對話的藝術家。",
      "text3": "我們的項目圍繞對話而構建——在媒介之間、世代之間、場景之間。每一場展覽、每一次合作都旨在創造意想不到的共鳴，開闢新的理解空間。"
    },
    "values": {
      "eyebrow": "我們的承諾",
      "title": "為何選擇 ORUS",
      "items": [
        {
          "title": "一種精選，而非一個計劃",
          "description": "九位藝術家，而非九十位。我們只代理我們深信不疑的藝術實踐，這使我們能夠為每位藝術家投入充分的關注、時間和資源，助力其雄心勃勃的發展。"
        },
        {
          "title": "時間中的關係",
          "description": "我們不只是銷售藝術品，我們構建收藏。每一個推薦都融入長遠的願景，尊重收藏家的歷程與藝術家的發展軌跡。"
        },
        {
          "title": "場景間的對話",
          "description": "我們在巴黎和台北的雙重據點為我們提供了觀察歐洲、非洲和亞洲新興藝術場景的獨特視角。我們創造了僅靠地理無法實現的連接。"
        }
      ]
    },
